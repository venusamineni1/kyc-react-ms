# Copy to .env.gcp and fill in real values before deploying.
# Used by: kubectl create secret generic kyc-secrets --from-env-file=.env.gcp -n kyc

JWT_SECRET=replace-with-64-byte-minimum-secret-key
DB_URL=jdbc:postgresql://CLOUD_SQL_PRIVATE_IP:5432/kycdb
DB_DRIVER=org.postgresql.Driver
DB_USER=kyc_app
DB_PASSWORD=replace-with-strong-db-password

SFTP_HOST=replace-with-sftp-host
SFTP_USER=replace-with-sftp-user
SFTP_PASSWORD=replace-with-sftp-password

GPG_PASSPHRASE=replace-with-gpg-passphrase
